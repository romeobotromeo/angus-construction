# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio (reuse from TextMarco)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+18882...   # 888 toll-free number

# Allowed SMS senders (whitelist)
